# ============================================================
#  Python .gitignore
# ============================================================

# Bytecode y caché
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Distribución y empaquetado
dist/
build/
eggs/
*.egg
*.egg-info/
.eggs/
wheels/
MANIFEST

# Entornos virtuales
.venv/
venv/
env/
ENV/
.env/
Scripts/

# Variables de entorno y configuración sensible
.env
.env.*
*.env
secrets.py
config.local.py

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# pytest y cobertura
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Linters y herramientas
.ruff_cache/
.pylint.d/

# IDEs y editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Logs y bases de datos locales
*.log
*.sqlite
*.sqlite3
*.db

# Archivos temporales
*.tmp
*.bak
*.orig